# Required: Your RetailExpress API key
# Generate at Settings > Integrations > API Management in REX Back Office
REX_API_KEY=your_api_key_here

# Required: Bearer token for MCP endpoint authentication
# Generate with: openssl rand -hex 32
MCP_AUTH_TOKEN=your_random_token_here

# Optional: Override the API base URL (defaults to https://api.retailexpress.com.au)
# REX_API_BASE_URL=https://api.retailexpress.com.au
